<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Apply the stored theme before first paint so a light-preferring OS
          never flashes the dark shell. Resolves "system" via matchMedia and
          writes the EFFECTIVE base to <html data-theme> — the same value
          theme.ts maintains once the bundle boots. For a "custom" setting with
          a matching dala:theme:cache, paint the cached base + inline
          --color-* overrides too, so the custom shell is on screen before the
          bundle loads; a cache miss falls back to the base light/dark exactly
          like a built-in theme (no wrong-color flash). Kept inline, tiny, and
          dependency-free on purpose: an external module would load too late to
          beat paint. phx-no-curly-interpolation so the JS braces are not read
          as HEEx. --%>
    <script phx-no-curly-interpolation>
      (function () {
        try {
          var setting = "system";
          var customId = null;
          var raw = localStorage.getItem("dala:theme");
          if (raw) {
            var parsed = JSON.parse(raw);
            if (parsed) {
              if (
                parsed.setting === "light" ||
                parsed.setting === "dark" ||
                parsed.setting === "custom"
              ) {
                setting = parsed.setting;
              }
              if (typeof parsed.customId === "string") customId = parsed.customId;
            }
          }
          var root = document.documentElement;
          if (setting === "custom" && customId) {
            var cacheRaw = localStorage.getItem("dala:theme:cache");
            if (cacheRaw) {
              var cache = JSON.parse(cacheRaw);
              if (
                cache &&
                cache.id === customId &&
                (cache.base === "light" || cache.base === "dark") &&
                cache.cssVars &&
                typeof cache.cssVars === "object"
              ) {
                root.setAttribute("data-theme", cache.base);
                for (var name in cache.cssVars) {
                  if (Object.prototype.hasOwnProperty.call(cache.cssVars, name)) {
                    root.style.setProperty(name, cache.cssVars[name]);
                  }
                }
                return;
              }
            }
          }
          var dark =
            setting === "dark" ||
            ((setting === "system" || setting === "custom") &&
              (!window.matchMedia ||
                window.matchMedia("(prefers-color-scheme: dark)").matches));
          root.setAttribute("data-theme", dark ? "dark" : "light");
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <meta name="auth-enabled" content={to_string(Dala.Auth.enabled?())} />
    <meta name="mcp-enabled" content={to_string(Application.get_env(:dala, :mcp_enabled, false))} />
    <meta name="dala-version" content={to_string(Application.spec(:dala, :vsn))} />
    <%= if assigns[:user_email] do %>
      <meta name="user-email" content={@user_email} />
    <% end %>
    <%= if assigns[:socket_token] do %>
      <meta name="socket-token" content={@socket_token} />
    <% end %>
    <.live_title default="Dala">Dala</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
  </head>
  <body>
    {@inner_content}
    <script defer phx-track-static type="module" src={~p"/assets/index.js"}>
    </script>
  </body>
</html>
